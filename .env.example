# Flask environment
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Database Configuration
# Option 1: Use individual database credentials (recommended for development)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=thinglistorg_db

# Option 2: Use DATABASE_URL (uncomment to use instead of individual DB_* variables)
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/thinglistorg_db

# Image storage
IMAGE_STORAGE_DIR=/home/simon/images
IMAGE_BASE_URL=https://images/com
IMAGE_OUTPUT_FORMAT=webp
ITEM_IMAGE_DISPLAY_SIZE=180
IMAGE_MAX_SIZE=16777216

# reCAPTCHA Configuration (optional)
RECAPTCHA_ENABLED=false
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=

# Registration Configuration
# Set to false to require invitation tokens for registration
# Use: python admin/manage_invitations.py generate
REGISTRATIONS_ENABLED=true
