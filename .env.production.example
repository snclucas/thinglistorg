# Production Environment Configuration Template
# Copy to .env.production and fill in actual values

# Flask Configuration
FLASK_ENV=production
FLASK_APP=app.py
SECRET_KEY=your-secret-key-here-min-32-chars-strongly-random

# Database Configuration
# Option 1: Use DATABASE_URL (recommended for production)
DATABASE_URL=mysql+pymysql://username:password@db-host:3306/thinglistorg_db

# Option 2: Use individual database credentials
# DB_HOST=db-host
# DB_PORT=3306
# DB_USER=username
# DB_PASSWORD=password
# DB_NAME=thinglistorg_db

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@example.com

# Image Upload Configuration
IMAGE_STORAGE_DIR=/var/www/thinglist/image_uploads
IMAGE_BASE_URL=/image-content/
IMAGE_OUTPUT_FORMAT=webp
ITEM_IMAGE_DISPLAY_SIZE=180

# Gunicorn Configuration
GUNICORN_WORKERS=4
GUNICORN_BIND=127.0.0.1:5000

# Security
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/thinglist/app.log

# Features
DEBUG=False
TESTING=False

# reCAPTCHA Configuration (optional)
RECAPTCHA_ENABLED=true
RECAPTCHA_PUBLIC_KEY=your-recaptcha-public-key
RECAPTCHA_PRIVATE_KEY=your-recaptcha-private-key

# Registration Configuration
# Set to false to require invitation tokens for registration
# Use: python admin/manage_invitations.py generate
REGISTRATIONS_ENABLED=true
